# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Celery (task queue / scheduler) — needs a running Redis broker.
# Beat runs the trading cycle every 20 minutes.
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# Set USE_SQLITE=True to fall back to a local SQLite file (handy for dev/tests).
# ---------------------------------------------------------------------------
USE_SQLITE=False
DB_NAME=trademind
DB_USER=trademind
DB_PASSWORD=trademind
DB_HOST=localhost
DB_PORT=5432

# ---------------------------------------------------------------------------
# JWT lifetimes (minutes / days)
# ---------------------------------------------------------------------------
ACCESS_TOKEN_LIFETIME_MIN=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# ---------------------------------------------------------------------------
# Email (credentials are emailed to new users). Console backend by default.
# ---------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=TradeMind AI <no-reply@trademind.ai>

# ---------------------------------------------------------------------------
# Ollama (local LLM)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Request timeout in seconds. Use 0 (or leave blank) for NO timeout —
# recommended for local LLMs on CPU, which can take minutes per generation.
OLLAMA_TIMEOUT=0

# ---------------------------------------------------------------------------
# Reddit (PRAW) — optional. Sentiment degrades gracefully if unset.
# ---------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trademind-ai/0.1

# ---------------------------------------------------------------------------
# Trading / risk configuration
# ---------------------------------------------------------------------------
PAPER_STARTING_CASH=100000
MAX_OPEN_TRADES=3
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04
MIN_CONFIDENCE=0.7
MAX_RSI=75
TRADE_QUANTITY=10
# Comma-separated watchlist the MarketDiscoveryAgent screens.
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM,V,WMT

# ---------------------------------------------------------------------------
# Default admin seeded by `python manage.py seed_data`
# ---------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@trademind.ai
ADMIN_PASSWORD=Admin@12345
